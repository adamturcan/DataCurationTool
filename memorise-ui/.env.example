# Base path for the app. Defaults to /DataCurationTool/ for the GitHub Pages
# deployment; use "/" for Docker or standalone local hosting.
VITE_BASE_PATH=/

# NLP API endpoints
VITE_NER_API_URL=https://ner-api.dev.memorise.sdu.dk/recognize
VITE_SEGMENT_API_URL=https://textseg-api.dev.memorise.sdu.dk/segment
VITE_CLASSIFY_API_URL=https://semtag-api.dev.memorise.sdu.dk/classify
VITE_TRANSLATION_API_URL=https://mt-api.dev.memorise.sdu.dk
